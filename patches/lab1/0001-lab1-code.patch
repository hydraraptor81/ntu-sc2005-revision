diff --git a/user/proccount.c b/user/proccount.c
new file mode 100644
index 0000000..7029a02
--- /dev/null
+++ b/user/proccount.c
@@ -0,0 +1,15 @@
+#include "kernel/types.h"
+#include "kernel/stat.h"
+#include "user/user.h"
+
+int
+main(int argc, char *argv[])
+{
+  int count;
+
+  count = getproccount();
+  printf("Active processes: %d\n", count);
+
+  exit(0);
+}
